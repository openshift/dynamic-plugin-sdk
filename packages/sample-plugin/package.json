{
  "name": "@monorepo/sample-plugin",
  "version": "0.0.0-fixed",
  "description": "Sample dynamic plugin project",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && yarn webpack",
    "build-prod": "yarn clean && NODE_ENV=production yarn webpack",
    "build-rspack": "yarn clean && NODE_ENV=production yarn rspack",
    "lint": "yarn run -T eslint $INIT_CWD",
    "webpack": "WEBPACK=1 node -r ts-node/register ./node_modules/.bin/webpack",
    "rspack": "RSPACK=1 node -r ts-node/register ./node_modules/.bin/rspack -c webpack.config.ts",
    "http-server": "http-server dist -p 9001 -c-1 --cors"
  },
  "devDependencies": {
    "@monorepo/sample-app": "portal:../sample-app",
    "@openshift/dynamic-plugin-sdk": "portal:../lib-core",
    "@openshift/dynamic-plugin-sdk-webpack": "portal:../lib-webpack",
    "@patternfly/react-core": "^6.4.0",
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "7.0.2",
    "http-server": "^14.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^7.0.2"
  },
  "installConfig": {
    "hoistingLimits": "dependencies"
  }
}
